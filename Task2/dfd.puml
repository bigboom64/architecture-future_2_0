@startuml
title Data Flow Diagram — Логические потоки данных между доменами (Будущее 2.0)

' ─────────────────────────────────────────────
' Внешние акторы (источники / потребители)
' ─────────────────────────────────────────────
actor "Врач / Пациент" as user
actor "Партнёр — Фарма" as pharma
actor "Партнёр — Устройства" as devices

' ─────────────────────────────────────────────
' Домены с явным указанием зоны ответственности
' ─────────────────────────────────────────────

package "Clinic Domain\n[Управление клиническими процессами]" as clinic {
  rectangle "Приём и запись\nна приём" as clinic_scheduling
  rectangle "Ведение\nмедкарты пациента" as clinic_emr
  rectangle "Выписка направлений\nи рецептов" as clinic_prescriptions
}

package "Fintech Domain\n[Финансовые операции и взаиморасчёты]" as fintech {
  rectangle "Процессинг платежей\nи транзакций" as fin_processing
  rectangle "Формирование счетов\nи актов" as fin_invoicing
  rectangle "Финансовая отчётность\nдля регуляторов" as fin_reporting
}

package "AI Services Domain\n[Обучение и инференс моделей]" as ai {
  rectangle "Обучение моделей\n(batch pipeline)" as ai_training
  rectangle "Инференс:\nдиагностика и прогнозы" as ai_inference
  rectangle "Управление версиями\nмоделей (Model Registry)" as ai_registry
}

package "Data Platform Domain\n[Интеграция, хранение и подготовка данных]" as dwh {
  rectangle "Шина событий\n(Event Bus / Kafka)" as dwh_bus
  rectangle "Сырое хранилище\n(Data Lake, raw-слой)" as dwh_lake
  rectangle "Слой обработки\n(DWH, очистка, обогащение)" as dwh_transform
  rectangle "Витрины данных\n(Data Marts)" as dwh_marts
  rectangle "Контроль качества\nданных (DQ)" as dwh_dq
}

' ─────────────────────────────────────────────
' Потоки: Внешние акторы → Домены
' ─────────────────────────────────────────────
user --> clinic_scheduling : Запись на приём\n(ФИО, дата, услуга)
pharma --> dwh_bus : Каталог препаратов и цен\n(обновления ассортимента)
devices --> dwh_bus : Телеметрия устройств\n(показатели здоровья, временны́е ряды IoT)

' ─────────────────────────────────────────────
' Потоки: Clinic Domain → Data Platform
' ─────────────────────────────────────────────
clinic_emr --> dwh_bus : Клинические события\n(диагноз, анализы, результаты осмотра)
clinic_prescriptions --> dwh_bus : Выписанные рецепты\n(МНН, дозировка, пациент ID)
clinic_scheduling --> fin_invoicing : Оказанные услуги\n(код услуги, пациент, дата)

note right of clinic
  Независимое развитие:
  внутренняя логика расписания,
  шаблоны медкарты, интеграции
  с ЕГИСЗ — без изменений
  других доменов.
end note

' ─────────────────────────────────────────────
' Потоки внутри Data Platform
' ─────────────────────────────────────────────
dwh_bus --> dwh_lake : Все входящие события\n(сырые, без изменений)
dwh_lake --> dwh_dq : Данные на проверку\n(полнота, форматы, дубли)
dwh_dq --> dwh_transform : Валидированные данные\n(готовы к обработке)
dwh_transform --> dwh_marts : Агрегаты и срезы\n(по доменам, периодам, сегментам)

note bottom of dwh
  Data Platform отвечает за:
  транспорт, хранение, качество,
  подготовку срезов.
  Бизнес-логика доменов
  здесь не реализуется.
end note

' ─────────────────────────────────────────────
' Потоки: Data Platform → AI Services
' ─────────────────────────────────────────────
dwh_marts --> ai_training : Обучающие датасеты\n(анонимизированные,\nразмечённые клинические записи)
dwh_marts --> ai_inference : Контекст пациента\n(последние показатели для скоринга)
ai_registry --> dwh_lake : Артефакты обученных моделей\n(версия, метрики, дата)

note right of ai
  Независимое развитие:
  смена алгоритмов, дообучение
  моделей, A/B-тестирование —
  без изменений схем DWH
  или логики Clinic.
end note

' ─────────────────────────────────────────────
' Потоки: AI Services → Домены-потребители
' ─────────────────────────────────────────────
ai_inference --> clinic_emr : Результаты диагностики\n(вероятность диагноза, маркеры риска)
ai_inference --> dwh_bus : Рекомендации по препаратам\n(для маршрутизации к Pharma)
dwh_bus --> pharma : Персонализированные рекомендации\n(препарат, дозировка, профиль пациента)
ai_inference --> devices : Корректировки параметров\n(пороги сигнализации, режим мониторинга)

' ─────────────────────────────────────────────
' Потоки: Data Platform → Fintech
' ─────────────────────────────────────────────
dwh_marts --> fin_reporting : Финансовые срезы\n(выручка по услугам, периодам, регионам)
dwh_marts --> fin_processing : Данные для сверки\n(транзакции партнёров для реконсиляции)

note left of fintech
  Независимое развитие:
  логика расчётов, тарифы,
  интеграции с банками —
  без изменений схем
  Clinic или AI.
end note

' ─────────────────────────────────────────────
' Потоки: Fintech → Data Platform
' ─────────────────────────────────────────────
fin_processing --> dwh_bus : Подтверждённые транзакции\n(статус, сумма, контрагент)
fin_reporting --> dwh_lake : Регуляторная отчётность\n(для архивирования и аудита)

@enduml
